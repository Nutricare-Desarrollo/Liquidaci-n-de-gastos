# Copia a .env y completa. NINGUN secreto se commitea.
PORT=8080

# Postgres (Azure Database for PostgreSQL Flexible Server)
DATABASE_URL=postgresql://user:pass@host:5432/nutricare?sslmode=require

# Entra (app registration / cuenta de servicio dedicada)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Azure Blob: URL de contenedor con SAS de escritura
AZURE_BLOB_CONTAINER_SAS_URL=https://cuenta.blob.core.windows.net/capturas?sv=...

# Azure AI Document Intelligence
AZURE_DOCINT_ENDPOINT=https://recurso.cognitiveservices.azure.com
AZURE_DOCINT_KEY=

# Buzon de facturacion (M365) leido via Graph
GRAPH_MAILBOX_USER_ID=facturacion@nutricare.co.cr

# D365 FO (servicio X++ expuesto)
FO_BASE_URL=https://org.operations.dynamics.com
FO_SERVICE_PATH=/api/services/NTCExpenseReportServiceGroup/NTCExpenseReportService/createExpenseReport
FO_SCOPE=https://org.operations.dynamics.com/.default
FO_TIMEOUT_MS=120000

# Almacenamiento de adjuntos/PDF: "blob" (Azure) o "sharepoint"
STORAGE_PROVIDER=sharepoint
# SharePoint (donde Nutricare guarda los PDF). Requiere app Entra con Sites.ReadWrite.All
SHAREPOINT_SITE_ID=contoso.sharepoint.com,<guid-site>,<guid-web>
SHAREPOINT_DRIVE_ID=
SHAREPOINT_CARPETA_BASE=Comprobantes Gastos

# Aprobaciones Teams: URL del trigger HTTP del flujo de Power Automate que
# crea el Teams Approval para el aprobador (se llama al Enviar). Requiere
# tambien User.Read.All para listar aprobadores desde Entra.
APPROVALS_FLOW_URL=

# --- Aprobacion Teams: enlace + callback ---
# URL publica del frontend (para el enlace de la tarjeta de Teams).
APP_BASE_URL=http://127.0.0.1:5173
# Secreto compartido: el flujo debe mandarlo en el header x-approval-secret al callback.
APPROVALS_CALLBACK_SECRET=pon-un-secreto-largo-aqui

# --- Autenticacion (Entra ID) ---
# 0/ausente = modo dev (sin login, usuario Admin). 1 = valida tokens reales de Entra.
AUTH_ENABLED=0
# Client ID (o api://<id>) de la app API registrada en Entra; debe coincidir con el "aud" del token.
API_AUDIENCE=
# Valores EXACTOS de los App Roles definidos en Entra.
ROLE_ADMIN=Admin
ROLE_CONTA=Contabilidad
# Roles del usuario dev cuando AUTH_ENABLED=0 (para probar las vistas por rol sin Azure).
# Ej: Admin  |  Contabilidad  |  (vacio) = usuario estandar
DEV_ROLES=Admin

# --- Filtro de usuarios (selector de aprobador) ---
USUARIOS_DOMINIO=nutricare.co.cr
# Substrings a excluir (por correo o nombre), separados por coma. Ej: sello promed,noreply,buzon
USUARIOS_EXCLUIR=

# --- Pruebas: permitir que el solicitante sea su propio aprobador ---
# 1 = permite autoaprobacion (SOLO para pruebas). Vacio/0 = regla estricta (produccion).
ALLOW_SELF_APPROVAL=0
